{
  "manifest_version": 3,
  "name": "Restricted Iframe Fixture",
  "version": "0.0.1",
  "key": "",
  "description": "Minimal extension that exposes a chrome-extension:// page for iframe repros",
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["page.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
