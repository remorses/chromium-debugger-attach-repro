{
  "manifest_version": 3,
  "name": "Debugger Attach Repro",
  "version": "0.0.1",
  "key": "",
  "description": "Minimal extension that calls raw chrome.debugger.attach on the active tab",
  "permissions": ["debugger", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["runner.html", "runner.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
